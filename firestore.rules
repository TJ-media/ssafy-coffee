// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // groups 컬렉션 내의 문서(모임 데이터)들에 대해서만 읽기 및 쓰기 허용
    match /groups/{groupId} {
      allow read, write: if true;
    }

    // menus 컬렉션은 읽기/쓰기 허용 (메뉴 데이터 로딩 및 관리용)
    match /menus/{menuId} {
      allow read: if true;
      allow write: if true;
    }

    // system 컬렉션 (관리자 비밀번호, 공지사항 등)
    match /system/{docId} {
      allow read, write: if true;
    }

    // menuRequests 컬렉션 (메뉴 신청)
    match /menuRequests/{requestId} {
      allow read, write: if true;
    }

    // 그 외의 모든 경로에 대해서는 접근을 완전히 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}